{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlyPhy",
  "version": "0.1.0",
  "identifier": "com.glyphy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GlyPhy",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#0a0a0f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Notas y tareas con conocimiento conectado",
    "longDescription": "GlyPhy es una aplicación de escritorio para la gestión avanzada de notas y tareas con knowledge graph, búsqueda instantánea y diseño premium."
  },
  "plugins": {}
}
